{
  "name": "customer-recovery-console",
  "version": "1.4.0",
  "private": true,
  "description": "Local advanced email recovery tool for authorized mailbox exports.",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "web:dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "start": "electron .",
    "dist": "npm run build && electron-builder",
    "check": "node --check electron/main.cjs && node --check electron/preload.cjs",
    "dist:win": "npm run build && electron-builder --win nsis --x64 --publish never",
    "dist:mac": "npm run build && electron-builder --mac dmg zip --x64 --arm64 --publish never",
    "dist:mac:x64": "npm run build && electron-builder --mac dmg zip --x64",
    "dist:mac:arm64": "npm run build && electron-builder --mac dmg zip --arm64",
    "dist:all-local": "npm run build && electron-builder -mw"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "papaparse": "latest",
    "react": "latest",
    "react-dom": "latest",
    "xlsx": "latest"
  },
  "devDependencies": {
    "concurrently": "latest",
    "cross-env": "latest",
    "electron": "latest",
    "electron-builder": "latest",
    "vite": "latest",
    "wait-on": "latest"
  },
  "build": {
    "appId": "com.customerrecovery.console",
    "productName": "Advanced Email Recovery Tool",
    "copyright": "Copyright © 2026 Advanced Email Recovery Tool",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "README.md",
      "COMPLIANCE_NOTES.md"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "mac": {
      "category": "public.app-category.business",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "Advanced Email Recovery Tool ${version}",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Advanced Email Recovery Tool",
      "uninstallDisplayName": "Advanced Email Recovery Tool"
    }
  },
  "author": "Nicholas Banton"
}
